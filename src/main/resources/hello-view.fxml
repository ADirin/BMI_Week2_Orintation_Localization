<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import java.awt.Insets?>
<?import java.awt.TextField?>
<?import java.awt.Label?>
<?import java.awt.Button?>
<VBox alignment="TOP_CENTER" spacing="16.0"
      xmlns:fx="http://javafx.com/fxml"
      fx:id="rootVBox"
      fx:controller="org.example.bmi_week2_orintation_localization.BMIController">

    <padding>
        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0"/>
    </padding>

    <HBox spacing="10">
        <Label fx:id="lblWeight" text="Weight (kg)"/>
        <TextField fx:id="tfWeight" promptText="e.g. 70"/>
    </HBox>

    <HBox spacing="10">
        <Label fx:id="lblHeight" text="Height (cm)"/>
        <TextField fx:id="tfHeight" promptText="e.g. 175"/>
    </HBox>

    <Button fx:id="btnCalculate"
            text="Calculate"
            onAction="#onCalculateClick"/>

    <Label fx:id="lblResult"/>

    <Label fx:id="lblLocalTime" text="Local Time"/>

    <HBox spacing="8">
        <Button text="EN" onAction="#onENClick"/>
        <Button text="FR" onAction="#onFRClick"/>
        <Button text="UR" onAction="#onURClick"/>
        <Button text="VI" onAction="#onVIClick"/>
        <Button text="FA" onAction="#onFAClick"/>
    </HBox>

</VBox>
